{
  "name": "el",
  "version": "0.0.1",
  "description": "CLI/TUI client for the Agent Host Protocol (AHP)",
  "type": "module",
  "bin": {
    "el": "./dist/index.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "LICENSE",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts",
    "!dist/**/*.map"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "node --test 'dist/**/*.test.js' 'dist/*.test.js'",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ahp",
    "ahp-types",
    "cli",
    "tui"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@microsoft/dev-tunnels-connections": "^1.3.41",
    "@microsoft/dev-tunnels-contracts": "^1.3.41",
    "@microsoft/dev-tunnels-management": "^1.3.41",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "typescript": "^5.7.0"
  }
}
